        function toggleMasteryInDictionary(id, event) \{\
            if (event) event.stopPropagation();\
            if (state.knownCardIds.has(id)) \{\
                state.knownCardIds.delete(id);\
            \} else \{\
                state.knownCardIds.add(id);\
            \}\
            savePersistence();\
            renderDictionary();\
            rebuildDeck();\
            renderCategorySelector();\
        \}\
\
        function toggleConfigModal(visible) \{\
            const modal = document.getElementById('config-modal');\
            if (visible) modal.classList.remove('hidden');\
            else modal.classList.add('hidden');\
        \}\
\
        function toggleKeyboardModal(visible) \{\
            const modal = document.getElementById('keyboard-modal');\
            if (visible) modal.classList.remove('hidden');\
            else modal.classList.add('hidden');\
        \}\
\
        function showToast(message) \{\
            const container = document.getElementById('toast-container');\
            const toast = document.createElement('div');\
            toast.className = "bg-stone-900 text-stone-100 px-3 py-1.5 rounded-xl shadow-md text-[10px] font-semibold border-l-4 border-emerald-500 flex items-center gap-1.5 mt-1 opacity-0 transition-all duration-300 transform translate-y-2 pointer-events-auto";\
            toast.innerHTML = `<span class="text-emerald-400">\uc0\u9889 </span> $\{message\}`;\
            \
            container.appendChild(toast);\
            requestAnimationFrame(() => \{\
                toast.classList.remove('opacity-0', 'translate-y-2');\
            \});\
            setTimeout(() => \{\
                toast.classList.add('opacity-0', 'translate-y-2');\
                setTimeout(() => toast.remove(), 300);\
            \}, 2000);\
        \}\
\
        window.addEventListener('keydown', (e) => \{\
            if (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'SELECT') return;\
\
            if (state.currentTab === 'study') \{\
                switch (e.code) \{\
                    case 'Space':\
                        e.preventDefault();\
                        flipCard();\
                        break;\
                    case 'ArrowRight':\
                        e.preventDefault();\
                        nextCard();\
                        break;\
                    case 'ArrowLeft':\
                        e.preventDefault();\
                        prevCard();\
                        break;\
                    case 'ArrowUp':\
                        e.preventDefault();\
                        speakItalianPhrase(null);\
                        break;\
                    case 'ArrowDown':\
                        e.preventDefault();\
                        markAsKnown();\
                        break;\
                \}\
            \}\
        \});\
\
        // Initialize Onload Tasks\
        window.onload = function () \{\
            loadPersistence();\
            initSpeechEngine();\
            rebuildDeck();\
            renderCategorySelector();\
        \};\
    </script>\
</body>\
</html>}