\
        // Custom Card Creator (Gemini Structured Generation)\
        let tempCustomCard = null;\
\
        async function generateTranslationAI() \{\
            const english = document.getElementById('custom-english-input').value.trim();\
            if (!english) return;\
\
            const loader = document.getElementById('creator-ai-loading');\
            const preview = document.getElementById('creator-preview-pane');\
            const genBtn = document.getElementById('creator-btn-generate');\
            const saveBtn = document.getElementById('creator-btn-save');\
\
            loader.classList.remove('hidden');\
            preview.classList.add('hidden');\
            saveBtn.classList.add('hidden');\
            genBtn.disabled = true;\
\
            const systemPrompt = "You are a bilingual translator. Translate user English queries to Italian. Return a strictly structured JSON response following the specified schema.";\
            const schema = \{\
                type: "OBJECT",\
                properties: \{\
                    italian: \{ type: "STRING", description: "The translated Italian phrase." \},\
                    english: \{ type: "STRING", description: "The original clean English phrase." \},\
                    phonetic: \{ type: "STRING", description: "Approximated phonetic representation for English speakers." \},\
                    category: \{ type: "STRING", enum: ["Greetings", "Getting Around", "Eat & Shop", "Time & Numbers", "Allergies"], description: "The best matched category out of the five." \}\
                \},\
                required: ["italian", "english", "phonetic", "category"]\
            \};\
\
            try \{\
                const jsonText = await callGemini(systemPrompt, `Translate English to Italian: "$\{english\}"`, schema);\
                const parsed = JSON.parse(jsonText);\
\
                tempCustomCard = \{\
                    id: "custom_" + Date.now(),\
                    category: parsed.category,\
                    italian: parsed.italian,\
                    english: parsed.english,\
                    phonetic: parsed.phonetic\
                \};\
\
                document.getElementById('creator-preview-italian').textContent = tempCustomCard.italian;\
                document.getElementById('creator-preview-phonetic').textContent = `"$\{tempCustomCard.phonetic\}"`;\
                document.getElementById('creator-preview-category').textContent = tempCustomCard.category;\
\
                loader.classList.add('hidden');\
                preview.classList.remove('hidden');\
                saveBtn.classList.remove('hidden');\
                genBtn.disabled = false;\
            \} catch (err) \{\
                console.error(err);\
                loader.classList.add('hidden');\
                genBtn.disabled = false;\
                showToast("Error communicating with language model.");\
            \}\
        \}\
\
        function saveCustomAICard() \{\
            if (!tempCustomCard) return;\
            state.customCards.push(tempCustomCard);\
            savePersistence();\
            rebuildDynamicDeck();\
            \
            // Reset active views\
            rebuildDeck();\
            renderCategorySelector();\
            toggleCreateModal(false);\
            \
            showToast(`Custom card "$\{tempCustomCard.italian\}" added!`);\
            tempCustomCard = null;\
        \}\
