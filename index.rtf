        function savePersistence() \{\
            try \{\
                localStorage.setItem('italian_known_cards', JSON.stringify(Array.from(state.knownCardIds)));\
                localStorage.setItem('italian_eng_first', JSON.stringify(state.showEnglishFirst));\
                localStorage.setItem('italian_auto_speak', JSON.stringify(state.autoSpeak));\
                localStorage.setItem('italian_custom_cards', JSON.stringify(state.customCards));\
