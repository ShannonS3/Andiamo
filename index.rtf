\
        async function submitUserChatMessage() \{\
            const input = document.getElementById('chat-input-field');\
            const text = input.value.trim();\
            if (!text) return;\
\
            input.value = '';\
            state.chatHistory.push(\{ sender: 'user', text: text \});\
            renderChatHistory();\
\
            // Insert temporary AI typing dot\
            state.chatHistory.push(\{ sender: 'ai', text: 'Typing...', showTranslation: false \});\
            renderChatHistory();\
\
            const scenario = SCENARIOS[state.activeScenario];\
            const systemPrompt = scenario.systemPrompt;\
            \
            // Build history context query\
            const contextQuery = state.chatHistory\
                .slice(0, -1) // skip typing dot\
                .map(msg => \{\
                    // Extract Italian version for context history feed\
                    const parsedText = msg.text.includes('|||') ? msg.text.split('|||')[0].trim() : msg.text;\
                    return `$\{msg.sender === 'user' ? 'User' : 'Coach'\}: $\{parsedText\}`;\
                \})\
                .join('\\n') + `\\nUser just said: "$\{text\}". Please write your conversational dialogue response in Italian. Correct errors if they made any in brackets, and ALWAYS append the English translation at the very end separated by a triple pipe '|||'.`;\
\
            try \{\
                const response = await callGemini(systemPrompt, contextQuery);\
                // Replace typing dot\
                state.chatHistory.pop();\
                state.chatHistory.push(\{ sender: 'ai', text: response, showTranslation: false \});\
                renderChatHistory();\
            \} catch (err) \{\
                state.chatHistory.pop();\
                state.chatHistory.push(\{ sender: 'ai', text: "[Failed to receive response from AI Coach. Check connection]", showTranslation: false \});\
                renderChatHistory();\
            \}\
