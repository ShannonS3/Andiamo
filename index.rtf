            setTimeout(() => \{\
                drawer.scrollIntoView(\{ behavior: 'smooth', block: 'center' \});\
            \}, 100);\
\
            const systemPrompt = "You are a master Italian travel guide and linguist. Break down phrases concisely with 1 key cultural tip, 1 tricky pronunciation advice, and 2 travel scenario examples. Do not write a greeting or intro.";\
            const query = `Analyze the phrase: "$\{card.italian\}" which means "$\{card.english\}". Present the breakdown beautifully with emojis as bullet points.`;\
