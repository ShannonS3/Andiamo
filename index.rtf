            state.isFlipped = !state.isFlipped;\
            const innerCard = document.getElementById('flashcard-inner');\
            if (state.isFlipped) \{\
                innerCard.classList.add('is-flipped');\
                if (state.showEnglishFirst && state.autoSpeak) \{\
