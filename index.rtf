\
        function startCustomTopic() \{\
            const topicInput = document.getElementById('custom-topic-input');\
            const topic = topicInput.value.trim();\
            if (!topic) \{\
                showToast("Please write a topic to discuss! \uc0\u55356 \u56814 \u55356 \u56825 ");\
                return;\
            \}\
\
            // Programmatically define the customized scenario structure\
            SCENARIOS.custom = \{\
                title: `Custom: $\{topic\}`,\
                aiPersona: `A friendly conversation companion excited to chat about "$\{topic\}".`,\
                initialPrompt: `Ciao! Ho saputo che ti piacerebbe fare conversazione su: "$\{topic\}". Davvero interessante! Ti va di iniziare dicendomi qualcosa a riguardo? ||| Hi! I heard you'd like to chat about: "$\{topic\}". Really interesting! Do you want to start by telling me something about it?`,\
                systemPrompt: `You are an encouraging and friendly Italian conversational companion chatting with an English-speaking learner about their chosen topic: "$\{topic\}". You MUST speak ONLY in beginner-to-intermediate level Italian (A1-B1 level), using simple sentence structures, basic high-frequency travel words, and very straightforward grammatical forms. Avoid advanced tenses, subjunctive moods, idiomatic jargon, or complex syntax. Keep your sentences travel-friendly, natural, and relatively brief (1-2 sentences). Gently point out any grammatical or vocabulary errors in English inside brackets [like this] before responding in Italian. At the very end of your response, you must ALWAYS provide an English translation of your dialogue response, separated by a triple pipe '|||' delimiter. Example: Italian response [grammar correction] ||| English translation`\
            \};\
\
            state.previousScenarioValue = 'custom';\
            state.activeScenario = 'custom';\
            state.chatHistory = [];\
\
            // Dynamic Option update inside dropdown\
            const customOption = document.querySelector('#chat-scenario-select option[value="custom"]');\
            if (customOption) \{\
                customOption.textContent = `\uc0\u55357 \u56492  Custom: $\{topic.substring(0, 16)\}$\{topic.length > 16 ? '...' : ''\}`;\
            \}\
\
            // Close modal cleanly\
            const modal = document.getElementById('custom-topic-modal');\
            modal.classList.add('hidden');\
\
            state.chatHistory.push(\{\
                sender: 'ai',\
                text: SCENARIOS.custom.initialPrompt,\
                showTranslation: false\
            \});\
            renderChatHistory();\
            showToast("Custom conversation initialized! \uc0\u55357 \u56492 ");\
        \}\
\
        function renderChatHistory() \{\
            const zone = document.getElementById('chat-messages-zone');\
            zone.innerHTML = '';\
\
            state.chatHistory.forEach((msg, index) => \{\
                const bubble = document.createElement('div');\
                bubble.className = "flex flex-col max-w-[85%] rounded-2xl p-3 text-xs shadow-xs " + \
                    (msg.sender === 'user' \
                        ? "bg-emerald-700 text-white ml-auto rounded-tr-none" \
                        : "bg-white text-stone-850 border border-stone-200 rounded-tl-none");\
                \
                // Parse standard or delimiter-based messages\
                let displayItalian = msg.text;\
                let displayEnglish = "";\
\
                if (msg.text.includes('|||')) \{\
                    const parts = msg.text.split('|||');\
                    displayItalian = parts[0].trim();\
                    displayEnglish = parts[1].trim();\
                \}\
\
                // Inline conversion of grammatical errors [corrections]\
                let formattedText = displayItalian;\
                if (msg.sender === 'ai' && formattedText.includes('[')) \{\
                    formattedText = formattedText.replace('[', '<div class="bg-indigo-50 border border-indigo-100 text-indigo-900 rounded-lg p-2 my-1.5 font-medium flex items-start gap-1"><i class="fa-solid fa-graduation-cap text-xs mt-0.5"></i><span>').replace(']', '</span></div>');\
                \}\
\
                let translationToggleMarkup = "";\
                if (msg.sender === 'ai' && displayEnglish) \{\
                    translationToggleMarkup = `\
                        <div class="mt-2 pt-1 border-t border-stone-100 flex flex-col gap-1.5">\
                            <button onclick="toggleChatTranslation($\{index\}, event)" class="text-[10px] text-stone-550 hover:text-emerald-700 font-bold flex items-center gap-1 transition self-start">\
                                <i class="fa-solid fa-language text-xs"></i> \
                                <span>$\{msg.showTranslation ? 'Hide English' : 'Show English'\}</span>\
                            </button>\
                            <div class="text-[11px] text-stone-600 font-normal italic leading-relaxed bg-stone-50 border border-stone-200 rounded-xl p-2.5 transition-all $\{msg.showTranslation ? '' : 'hidden'\}">\
                                $\{displayEnglish\}\
                            </div>\
                        </div>\
                    `;\
                \}\
\
                bubble.innerHTML = `\
                    <span class="text-[9px] uppercase tracking-wider font-extrabold opacity-60 mb-1">\
                        $\{msg.sender === 'user' ? 'Tu (You)' : 'Coach'\}\
                    </span>\
                    <div class="leading-relaxed font-semibold">$\{formattedText\}</div>\
                    $\{translationToggleMarkup\}\
                `;\
                zone.appendChild(bubble);\
            \});\
\
            // Smooth scroll to bottom\
            setTimeout(() => \{\
                zone.scrollTop = zone.scrollHeight;\
            \}, 50);\
        \}\
\
        // Toggle the visible state of the English translation segment inside any chat balloon\
        function toggleChatTranslation(index, event) \{\
            if (event) event.stopPropagation();\
            state.chatHistory[index].showTranslation = !state.chatHistory[index].showTranslation;\
            renderChatHistory();\
