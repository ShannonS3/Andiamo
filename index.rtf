        function getPhoneticAid(phrase) \{\
            let p = phrase.toLowerCase();\
            p = p.replace(/ch/g, 'k')\
                 .replace(/gli/g, 'lyee')\
                 .replace(/gn/g, 'ny')\
                 .replace(/c([ie])/g, 'ch$1')\
                 .replace(/g([ie])/g, 'j$1')\
                 .replace(/sc([ie])/g, 'sh$1')\
                 .replace(/z/g, 'ts')\
                 .replace(/qu/g, 'kw')\
                 .replace(/u/g, 'oo');\
            return p;\
        \}\
