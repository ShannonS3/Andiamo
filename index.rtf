            for (let i = state.deck.length - 1; i > 0; i--) \{\
                const j = Math.floor(Math.random() * (i + 1));\
                [state.deck[i], state.deck[j]] = [state.deck[j], state.deck[i]];\
            \}\
            state.currentIndex = 0;\
            renderCard();\
            showToast("Shuffled! \uc0\u55357 \u56576 ");\
