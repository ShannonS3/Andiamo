                if (savedEngFirst !== null) \{\
                    state.showEnglishFirst = JSON.parse(savedEngFirst);\
                    document.getElementById('toggle-english-first').checked = state.showEnglishFirst;\
                \}\
                const savedAutoSpeak = localStorage.getItem('italian_auto_speak');\
                if (savedAutoSpeak !== null) \{\
                    state.autoSpeak = JSON.parse(savedAutoSpeak);\
                    document.getElementById('toggle-auto-speak').checked = state.autoSpeak;\
                \}\
                const storedCustom = localStorage.getItem('italian_custom_cards');\
                if (storedCustom) \{\
                    state.customCards = JSON.parse(storedCustom);\
                \}\
                rebuildDynamicDeck();\
            \} catch (e) \{\
                console.warn("Storage restricted or unavailable. Running dynamically in sandbox.", e);\
            \}\
        \}\
