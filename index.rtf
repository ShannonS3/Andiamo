        function speakItalianPhrase(event, customText = null) \{\
            if (event) event.stopPropagation();\
            if (!synth) return;\
            synth.cancel();\
\
            const currentCard = state.deck[state.currentIndex];\
            if (!currentCard && !customText) return;\
\
            const textToSpeak = customText || currentCard.italian;\
            const cleanText = textToSpeak.replace('\'85', '').replace('...', '');\
